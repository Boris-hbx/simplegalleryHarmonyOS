// =============================================================================
// GalleryFormAbility.ets — FormExtensionAbility for home screen gallery widget
// PAT-026: Reads pre-cached thumbnail from filesDir (generated by main process).
// PIT-073: This runs in a SEPARATE process — no photoAccessHelper, no heavy ops.
// PIT-072: formImages key must change each time or Image component won't refresh.
// =============================================================================

import { FormExtensionAbility, formBindingData, formProvider } from '@kit.FormKit'
import { Want } from '@kit.AbilityKit'
import { fileIo } from '@kit.CoreFileKit'

// Cache path constants — must match WidgetCacheManager
const CACHE_DIR_NAME: string = 'widget_cache'
const DEFAULT_THUMB_NAME: string = 'default_thumb.jpg'

export default class GalleryFormAbility extends FormExtensionAbility {

  onAddForm(want: Want): formBindingData.FormBindingData {
    const formId: string = want.parameters?.['ohos.extra.param.key.form_identity'] as string || ''
    console.info('[Widget] onAddForm formId=' + formId)

    // Try to load cached thumbnail immediately
    this.refreshFromCache(formId)

    // Return placeholder — async refresh will update if cache exists
    const placeholderData: Record<string, Object> = {
      'thumbnailUri': '',
      'folderName': '图库',
      'showFolderName': true
    }
    return formBindingData.createFormBindingData(placeholderData)
  }

  onRemoveForm(formId: string): void {
    console.info('[Widget] onRemoveForm formId=' + formId)
    // Phase 2: Clean up WidgetsDao record (requires DB init in this process)
    // For now, just log — DB cleanup handled when main process runs
  }

  onUpdateForm(formId: string): void {
    console.info('[Widget] onUpdateForm formId=' + formId)
    this.refreshFromCache(formId)
  }

  onFormEvent(formId: string, message: string): void {
    console.info('[Widget] onFormEvent formId=' + formId + ' message=' + message)
  }

  // Read pre-cached thumbnail from filesDir and push to widget via formImages.
  // PIT-073: This must complete in < 5 seconds. Reading a local file takes < 100ms.
  private async refreshFromCache(formId: string): Promise<void> {
    let srcFile: fileIo.File | null = null
    try {
      const cachePath: string = this.context.filesDir + '/' + CACHE_DIR_NAME + '/' + DEFAULT_THUMB_NAME

      // Check if cache file exists
      const exists: boolean = fileIo.accessSync(cachePath)
      if (!exists) {
        console.info('[Widget] No cache file found, showing placeholder')
        return
      }

      // Open cache file for reading — fd is what formImages needs
      srcFile = fileIo.openSync(cachePath, fileIo.OpenMode.READ_ONLY)

      // PIT-072: Key must change each time or Image component won't refresh
      const thumbKey: string = 'widgetThumb_' + Date.now().toString()

      const formImages: Record<string, number> = {}
      formImages[thumbKey] = srcFile.fd

      const data: Record<string, Object> = {
        'thumbnailUri': thumbKey,
        'folderName': '图库',
        'showFolderName': true,
        'formImages': formImages
      }

      const bindingData: formBindingData.FormBindingData = formBindingData.createFormBindingData(data)
      await formProvider.updateForm(formId, bindingData)

      console.info('[Widget] refreshFromCache succeeded for formId=' + formId + ' key=' + thumbKey)
    } catch (e) {
      console.error('[Widget] refreshFromCache failed: ' + (e as Error).message)
    } finally {
      if (srcFile !== null) {
        try {
          fileIo.closeSync(srcFile)
        } catch (_) {
          // Ignore close errors
        }
      }
      // Do NOT delete cache file — it will be reused for next refresh
    }
  }
}
